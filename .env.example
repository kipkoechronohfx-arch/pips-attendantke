# Pips Attendant — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB Atlas ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Security ────────────────────────────────────────────────────
# Strong random secret for JWT signing (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# Admin panel access key (sent as x-admin-key header)
ADMIN_KEY=your_admin_key_here

# Legacy VIP password (for global password access mode)
VIP_PASSWORD=PIPSVIP2026

# ── App URL (used for email links, Telegram webhook) ────────────
APP_URL=https://pips-attendantke.onrender.com
# Render sets this automatically:
# RENDER_EXTERNAL_URL=https://pips-attendantke.onrender.com

# ── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_VIP_CHAT_ID=-1001234567891

# ── M-Pesa Payments (Payhero) ───────────────────────────────────
PAYHERO_API_USER=your_payhero_username
PAYHERO_API_PASS=your_payhero_password
PAYHERO_CHANNEL_ID=your_channel_id

# ── Crypto Wallet Addresses (USDT) ──────────────────────────────
USDT_WALLET_TRC20=your_trc20_wallet_address
USDT_WALLET_BEP20=your_bep20_wallet_address
USDT_WALLET_ERC20=your_erc20_wallet_address

# ── SendGrid Email ───────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@pipsattendant.com

# ── Web Push Notifications (VAPID) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ── AI Support Assistant (Zuri) ─────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# If not set, the chat widget will be hidden automatically.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin 2FA (TOTP) ────────────────────────────────────────────
# Set automatically when you complete /api/admin/2fa/setup
# ADMIN_2FA_SECRET=your_totp_base32_secret
